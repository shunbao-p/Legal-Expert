# LLM（Kimi）
MOONSHOT_API_KEY=your_moonshot_api_key_here
# LLM（DeepSeek）
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=all-in-rag
NEO4J_DATABASE=neo4j

# Milvus
MILVUS_HOST=localhost
MILVUS_PORT=19530

# 模型
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
LLM_MODEL=kimi-k2-0711-preview
LLM_REQUEST_TIMEOUT_SECONDS=60

# 多模型分流（固定分流 + 主备）
LLM_GENERATION_PRIMARY_PROVIDER=kimi
LLM_GENERATION_PRIMARY_MODEL=kimi-k2-0711-preview
LLM_GENERATION_BACKUP_PROVIDER=deepseek
LLM_GENERATION_BACKUP_MODEL=deepseek-chat
LLM_ASSIST_PRIMARY_PROVIDER=deepseek
LLM_ASSIST_PRIMARY_MODEL=deepseek-chat
LLM_ASSIST_BACKUP_PROVIDER=kimi
LLM_ASSIST_BACKUP_MODEL=kimi-k2-0711-preview

# 日志
LOG_LEVEL=INFO
