# LLM（Kimi）
MOONSHOT_API_KEY=your_moonshot_api_key_here
# LLM（DeepSeek）
DEEPSEEK_API_KEY=your_deepseek_api_key_here

# Neo4j
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=all-in-rag
NEO4J_DATABASE=neo4j

# Milvus
MILVUS_HOST=localhost
MILVUS_PORT=19530
RECALL_POOL_K=50
ANSWER_TOP_K=5
TRUE_RERANK_ENABLED=true
RERANKER_MODEL_NAME=BAAI/bge-reranker-v2-m3
RERANKER_DEVICE=auto
RERANKER_BATCH_SIZE=8
RERANKER_MAX_LENGTH=512
GRAPH_ENTITY_MAX_LEN=20
GRAPH_GROUNDING_RELAX_ENABLED=true
GRAPH_ENTITY_MAX_LEN_RELAXED=32
GRAPH_RELAXED_MIN_TERM_LEN=2
GRAPH_GROUNDING_CONTAINS_ENABLED=false
GRAPH_GROUNDING_CONTAINS_REQUIRE_LEGAL_SIGNAL=true
GRAPH_QUALITY_GATE_ENABLED=true
GRAPH_QUALITY_MIN_RELEVANCE=0.55
GRAPH_LOW_QUALITY_MAX_KEEP=1
GRAPH_LOW_QUALITY_PENALTY=0.35

# 模型
EMBEDDING_MODEL=BAAI/bge-small-zh-v1.5
LLM_MODEL=kimi-k2-0711-preview
LLM_REQUEST_TIMEOUT_SECONDS=60

# 多模型分流（固定分流 + 主备）
LLM_GENERATION_PRIMARY_PROVIDER=kimi
LLM_GENERATION_PRIMARY_MODEL=kimi-k2-0711-preview
LLM_GENERATION_BACKUP_PROVIDER=deepseek
LLM_GENERATION_BACKUP_MODEL=deepseek-chat
LLM_ASSIST_PRIMARY_PROVIDER=deepseek
LLM_ASSIST_PRIMARY_MODEL=deepseek-chat
LLM_ASSIST_BACKUP_PROVIDER=kimi
LLM_ASSIST_BACKUP_MODEL=kimi-k2-0711-preview

# 日志
LOG_LEVEL=INFO

# LangSmith（观测）
LANGSMITH_TRACING=true
LANGSMITH_API_KEY=your_langsmith_api_key_here
LANGSMITH_PROJECT=Legal-evolution-dev
LANGSMITH_ENDPOINT=https://api.smith.langchain.com
